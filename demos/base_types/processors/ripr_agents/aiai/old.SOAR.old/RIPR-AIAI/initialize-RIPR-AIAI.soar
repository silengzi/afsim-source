sp {propose*initialize-RIPR-AIAI
   (state <s> ^superstate nil
             -^name)
-->
   (<s> ^operator <o> +)
   (<o> ^name initialize-RIPR-AIAI)
   (write (crlf) |Propose init|)
}

sp {apply*initialize-RIPR-AIAI
   (state <s> ^operator <op>)
   (<op> ^name initialize-RIPR-AIAI)
-->
   (<s> ^name RIPR-AIAI)
   (write (crlf) |Done with init!|)
}

